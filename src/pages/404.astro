---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="نتیجه مصاحبه - پذیرفته شده"
  description="تبریک! شما در مصاحبه دوره ML پذیرفته شدید."
>
  <div class="text-center py-12">
    <div class="text-2xl font-bold text-[var(--color-foreground)] mb-4">
      404
    </div>
    <h2 class="text-2xl font-bold text-[var(--color-foreground)] mb-4">
      صفحه مورد نظر یافت نشد
    </h2>

    <p>
      <a
        href="/"
        class="flex gap-1 items-center justify-center hover:underline text-[var(--color-primary)]"
      >
        <span> رفتن به صفحه اصلی</span>
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
          ></path>
        </svg>
      </a>
    </p>
  </div>
</BaseLayout>
