        <!-- Course Details -->
        <ContentCard title="اطلاعات برگزاری">
            <svg
                slot="icon"
                class="w-5 h-5 text-[var(--color-primary)]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"
                ></path>
            </svg>

            <!-- Add your course details here -->
            <p>
                <!-- توضیحات مربوط به شرایط دوره، زمان‌بندی، سرفصل‌ها و ... -->
                <b class="font-bold"> محل برگزاری: </b>
                یزد، خیابان کاشانی، خیابان چمران، کارخانه نوآوری درخشان، اتاق جلسات
                <br />
                <b class="font-bold"> زمان : </b>
                پنجشنبه ۷ اسفند، ساعت ۱۵ تا ۱۸
                <br />
                <span class="flex gap-1 items-center">
                    <span>
                        <b class="font-bold"> مدرس: </b>
                    </span>

                    <a
                        href="https://www.linkedin.com/in/ali-baghernia/"
                        target="_blank"
                        class="flex gap-1 items-center justify-center hover:underline text-[var(--color-primary)]"
                    >
                        <span> علی باقرنیا </span>
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                            ></path>
                        </svg>
                    </a>
                </span>
                <b class="font-bold"> نکته: </b>
                حتما با خود لپ‌تاپ بیاورید
                <br />
            </p>
        </ContentCard>

        <!-- Important Notes -->
        <ContentCard title="سرفصل ها">
            <svg
                slot="icon"
                class="w-5 h-5 text-[var(--color-primary)]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"
                ></path>
            </svg>

            <!-- Add important notes here -->
            <p>
                <div class="max-w-mdz mx-auto bg-gray-50 p-4 rounded-lg">
                    <ul class="space-y-4">
                        <!-- بخش اول -->
                        <li class="bg-white p-3 rounded-md shadow-sm">
                            <details class="list-none" open>
                                <summary
                                    class="font-bold text-[var(--color-primary)] cursor-pointer"
                                >
                                    آشنایی با پایتون
                                </summary>
                                <ul
                                    class="list-disc list-inside mt-3 space-y-2 pr-3"
                                >
                                    <li class="">کاربرد ها</li>

                                    <li class="">
                                        تفاوت زبان مفسری و کامپایلری
                                    </li>
                                    <li class="">
                                        پیاده سازی های مختلف پایتون - CPython
                                    </li>
                                    <li class="">نصب پایتون</li>
                                    <li class="">
                                        اجرای کد پایتون
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>از طریق کامند لاین</li>
                                            <li>از طریق VSCode</li>
                                            <li>از طریق Jupyter Notebook</li>
                                            <li>
                                                اجرای کد در حالت Interactive
                                            </li>
                                        </ul>
                                    </li>
                                    <li class="">سینتکس کلی</li>
                                    <li class="">قواعد PEP 8</li>
                                    <li class="">فرق بین ماژول و پکیج</li>
                                    <li class="">نحوه خواندن خطا ها</li>
                                </ul>
                            </details>
                        </li>

                        <!-- بخش دوم -->
                        <li class="bg-white p-3 rounded-md shadow-sm">
                            <details class="list-none">
                                <summary
                                    class="font-bold text-[var(--color-primary)] cursor-pointer"
                                >
                                    محیط توسعه
                                </summary>
                                <ul
                                    class="list-disc list-inside mt-3 space-y-2 pr-3"
                                >
                                    <li class="">تفاوت IDE و Code Editor</li>

                                    <li class="">
                                        آشنایی با vs code
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>Command Palette</li>
                                            <li>
                                                مدیریت فایل و پروژه و اشنایی با
                                                ورک اسپیس
                                            </li>
                                            <li>میانبرها و تنظیمات اولیه</li>
                                            <li>پلاگین ها</li>
                                        </ul>
                                    </li>

                                    <li class="">
                                        Jupyter Notebook
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>آشنایی با فایل های .md</li>
                                        </ul>
                                    </li>
                                    <li class="">
                                        آشنایی با کامند لاین
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>ساختار یک کامند</li>
                                            <li>
                                                آشنایی با Environment Variable
                                            </li>
                                            <li>
                                                کامند های مقدماتی: cd, ls, dir,
                                                pwd, cat, less, mkdir , clear ,
                                                exit , echo, history
                                            </li>
                                            <li>مفهوم اینترفیس</li>
                                            <li>تفاوت Cli, GUI و TUI</li>
                                        </ul>
                                    </li>
                                </ul>
                            </details>
                        </li>
                        <!-- asdsadasdasdsad -->
                        <li class="bg-white p-3 rounded-md shadow-sm">
                            <details class="list-none">
                                <summary
                                    class="font-bold text-[var(--color-primary)] cursor-pointer"
                                >
                                    نگاهی عمیق به متغییر ها
                                </summary>
                                <ul
                                    class="list-disc list-inside mt-3 space-y-2 pr-3"
                                >
                                    <li class="">قواعد نام گذاری</li>
                                    <li class="">تفاوت _var, __var, __var__</li>
                                    <li class="">
                                        تفاوت بین Mutable و Immutable
                                    </li>
                                    <li class="">تایع id</li>
                                    <li class="">تابع type</li>
                                    <li class="">Type Hint</li>
                                    <li class="">ثابت ها</li>
                                    <li class="">
                                        مفاهیم object identity، object value،
                                        reference
                                    </li>
                                    <li class="">تفاوت بین is و ==</li>
                                </ul>
                            </details>
                        </li>
                        <!-- سسسسسسسسسسسسسسسسسسسسسسسسسسس -->
                        <!-- asdsadasdasdsad -->
                        <li class="bg-white p-3 rounded-md shadow-sm">
                            <details class="list-none">
                                <summary
                                    class="font-bold text-[var(--color-primary)] cursor-pointer"
                                >
                                    انواع داده
                                </summary>
                                <ul
                                    class="list-disc list-inside mt-3 space-y-2 pr-3"
                                >
                                    <li class="">
                                        نحوه انتخاب مناسب ترین نوع برای هر مقدار
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>
                                                مثلا کدملی را توی str ذخیره کنم
                                                یا int
                                            </li>
                                        </ul>
                                    </li>
                                    <li class="">تبدیل انواع داده به یکدیگر</li>
                                    <li class="">
                                        str
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>Escape Characters</li>
                                            <li>Slicing</li>
                                            <li>مقایسه lexicographical</li>
                                            <li>تابع len</li>
                                            <li>تابع split</li>
                                            <li>تابع replace</li>
                                            <li>تابع strip</li>
                                            <li>تابع lower</li>
                                            <li>تابع upper</li>
                                            <li>تابع find</li>
                                            <li>تابع index</li>
                                            <li>تابع center</li>
                                            <li>تابع title</li>
                                            <li>تابع isidentifier</li>
                                            <li>عملگر +</li>
                                            <li>عملگر *</li>
                                        </ul>
                                    </li>
                                    <li class="">int</li>
                                    <li class="">
                                        float
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>
                                                Floating-Point Precision Error
                                            </li>
                                            <li>پکیج decimal</li>
                                        </ul>
                                    </li>
                                    <li class="">bool</li>
                                    <li class="">None</li>
                                </ul>
                            </details>
                        </li>
                        <!-- asjkddkajndkjsadndnasjd -->
                        <li class="bg-white p-3 rounded-md shadow-sm">
                            <details class="list-none">
                                <summary
                                    class="font-bold text-[var(--color-primary)] cursor-pointer"
                                >
                                    دیگر
                                </summary>
                                <ul
                                    class="list-disc list-inside mt-3 space-y-2 pr-3"
                                >
                                    <li class="">کامنت و docstrings</li>
                                    <li class="">تبدیل انواع داده به یکدیگر</li>
                                    <li class="">
                                        توابع زیر
                                        <ul
                                            class="list-circle list-inside mr-5 mt-2 space-y-1 text-sm text-gray-600"
                                        >
                                            <li>callable</li>
                                            <li>print</li>
                                            <li>help</li>
                                            <li>dir</li>
                                            <li>exit</li>
                                        </ul>
                                    </li>
                                    <li class="">مفهوم ابجکت</li>
                                    <li class="">مفهوم کلمات کلیدی</li>
                                    <li class="">مفهوم فانکشن</li>
                                </ul>
                            </details>
                        </li>
                    </ul>
                </div>
            </p>
        </ContentCard>

        <ContentCard title="تمرین ها">
            <svg
                slot="icon"
                class="w-5 h-5 text-[var(--color-primary)]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"
                ></path>
            </svg>

            <!-- Add your course details here -->
            <p>به زودی...</p>
        </ContentCard>
    </div>

    <!-- Sponsors -->
    <Sponsors slot="sponsors" />
</BaseLayout>
