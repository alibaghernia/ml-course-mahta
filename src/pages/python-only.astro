---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusBadge from "../components/StatusBadge.astro";
import ContentCard from "../components/ContentCard.astro";
import ActionButton from "../components/ActionButton.astro";
import Sponsors from "../components/Sponsors.astro";

// -- Configuration: Update these values --
const applicantName = "";
const pythonTelegramLink = "https://t.me/+8dP9rekZHIs3Yzg8"; // لینک گروه تلگرام دوره پایتون
---

<BaseLayout
  title="نتیجه مصاحبه - دوره پایتون"
  description="شما به دوره پایتون پیش‌نیاز دعوت شدید."
>
  <!-- Greeting & Status -->
  <div
    class="mb-8 text-center"
    x-data="{ show: false }"
    x-init="setTimeout(() => show = true, 100)"
  >
    <div
      x-show="show"
      x-transition:enter="transition ease-out duration-500"
      x-transition:enter-start="opacity-0 translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
    >
      <p class="text-[var(--color-muted-foreground)] mb-3">داوطلب عزیز</p>
      <!-- <div class="flex justify-center mb-4">
        <StatusBadge variant="info" label="دعوت به دوره پایتون" />
      </div> -->
      <h2
        class="text-2xl sm:text-3xl font-extrabold text-[var(--color-foreground)] text-balance"
      >
        شما به دوره پایتون پیش‌نیاز دعوت شدید
      </h2>
    </div>
  </div>

  <!-- Content Sections -->
  <div class="space-y-6">
    <!-- Interview Result Details -->
    <ContentCard title="نتیجه ارزیابی">
      <svg
        slot="icon"
        class="w-5 h-5 text-[var(--color-primary)]"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z"
        ></path>
      </svg>
      <p>
        ممنون از زمانی که برای شرکت در مصاحبه گذاشتید. با توجه به عملکرد شما،
        <b>
          امکان پذیرش مستقیم شما در دوره ML وجود ندارد ما تصمیم گرفتیم که شما را
          به دوره پایتون پیش‌نیاز دعوت کنیم.
        </b>
        <br />
        <br />
        این دوره به شما کمک می‌کند تا مهارت‌های لازم برای ورود به دوره یادگیری ماشین
        را کسب کنید.
        <br />
        این دوره
        <b> رایگان </b>
        است و در انتهای دوره
        <b>
          بر اساس عملکرد شرکت کنندگان امکان پذیرش در دوره یادگیری ماشین وجود
          دارد.
        </b>
      </p>
    </ContentCard>

    <!-- Python Course Details -->
    <ContentCard title="درباره دوره پایتون">
      <svg
        slot="icon"
        class="w-5 h-5 text-[var(--color-primary)]"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
        ></path>
      </svg>
      <p>
        <!-- توضیحات مربوط به شرایط دوره، زمان‌بندی، سرفصل‌ها و ... -->
        <b class="font-bold"> تعداد جلسات: </b>
        ۸ جلسه آموزشی ۳ ساعته
        <br />
        <b class="font-bold"> زمان برگزاری: </b>
        از ۷ اسفند تا ۲۵ اسفند
        <br />
        <span class="flex gap-1 items-center">
          <span>
            <b class="font-bold"> مدرس: </b>
          </span>

          <a
            href="https://www.linkedin.com/in/ali-baghernia/"
            target="_blank"
            class="flex gap-1 items-center justify-center hover:underline text-[var(--color-primary)]"
          >
            <span> علی باقرنیا </span>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              ></path>
            </svg>
          </a>
        </span>
        <!-- <br /> -->
        <span class="flex gap-1 items-center">
          <span>
            <b class="font-bold">سرفصل ها و اطلاعات بیشتر از جلسه اول:</b>
          </span>

          <a
            href="/python-course/session-1"
            target="_blank"
            class="flex gap-1 items-center justify-center hover:underline text-[var(--color-primary)]"
          >
            <span> مشاهده </span>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              ></path>
            </svg>
          </a>
        </span>
      </p>
    </ContentCard>

    <!-- Call to Action -->
    <div
      class="bg-[var(--color-info-bg)] border border-[var(--color-info)]/20 rounded-xl p-6 sm:p-8 text-center"
    >
      <h3 class="text-lg font-bold text-[var(--color-foreground)] mb-2">
        عضویت در گروه دوره پایتون
      </h3>
      <p class="text-[var(--color-muted-foreground)] text-sm mb-6">
        <!-- توضیحات مربوط به عضویت در گروه -->
      </p>
      <ActionButton href={pythonTelegramLink} variant="primary">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
          ></path>
        </svg>
        عضویت در گروه تلگرام پایتون
      </ActionButton>
    </div>
  </div>

  <!-- Sponsors -->
  <Sponsors slot="sponsors" />
</BaseLayout>
