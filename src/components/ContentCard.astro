---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<section class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-6 sm:p-8">
  {title && (
    <h2 class="text-lg font-bold text-[var(--color-foreground)] mb-4 flex items-center gap-2">
      <slot name="icon" />
      {title}
    </h2>
  )}
  <div class="text-[var(--color-muted-foreground)] leading-relaxed space-y-4">
    <slot />
  </div>
</section>
