---
interface Props {
  variant: 'success' | 'info';
  label: string;
}

const { variant, label } = Astro.props;

const styles = {
  success: 'bg-[var(--color-success-bg)] text-[var(--color-success)] border-[var(--color-success)]/20',
  info: 'bg-[var(--color-info-bg)] text-[var(--color-info)] border-[var(--color-info)]/20',
};
---

<span class:list={['inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium border', styles[variant]]}>
  {variant === 'success' && (
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
    </svg>
  )}
  {variant === 'info' && (
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
    </svg>
  )}
  {label}
</span>
