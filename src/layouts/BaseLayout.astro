---
import "@fontsource-variable/vazirmatn";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "نتایج مصاحبه دوره یادگیری ماشین" } = Astro.props;
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body
    class="min-h-screen bg-[var(--color-background)] text-[var(--color-foreground)] font-vazir antialiased"
  >
    <div class="flex flex-col min-h-screen">
      <header class="border-b border-[var(--color-border)]">
        <div class="max-w-3xl mx-auto px-4 py-6 sm:px-6 lg:px-8">
          <div class="flex items-center justify-center gap-3">
            <div
              class="w-10 h-10 rounded-lg bg-[var(--color-primary)] flex items-center justify-center"
            >
              <svg
                class="w-6 h-6 text-[var(--color-primary-foreground)]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"
                ></path>
              </svg>
            </div>
            <a href="/">
              <h1 class="text-lg font-bold text-[var(--color-foreground)]">
                دوره یادگیری ماشین | مهتا
              </h1>
            </a>
          </div>
        </div>
      </header>

      <main class="flex-1">
        <div class="max-w-3xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
          <slot />
        </div>
      </main>

      <footer
        class="border-t border-[var(--color-border)] bg-[var(--color-muted)]"
      >
        <div class="max-w-3xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
          <slot name="sponsors" />
          <div
            class="text-center text-sm text-[var(--color-muted-foreground)] mt-6"
          >
            <p>تمامی حقوق محفوظ است.</p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
